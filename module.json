{
    "id": "token-action-hud-cthack",
    "title": "Token Action HUD Cthulhu Hack",
    "description": "Token Action HUD is a repositionable HUD of actions for a selected token.",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Kristov"
        }
    ],
    "esmodules": [
        "scripts/init.mjs"
    ],
    "styles": [
        "styles.css"
    ],
    "languages": [
        {
            "lang": "en",
            "name": "English",
            "path": "lang/en.json"
        },
        {

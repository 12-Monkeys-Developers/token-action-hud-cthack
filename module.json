                    "minimum": "2.0.0",
                    "verified": "2.0.16"
                }
            }
        ],
        "systems": [
      {
        "id": "cthack",
        "type": "system",
        "compatibility": {
          "verified": "5.6.0"
        }
      }
        ]
    }
